rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function getCategory(categoryId) {
      return get(/databases/$(database)/documents/categories/$(categoryId)).data;
    }

    // Accounts collection
    match /accounts/{accountId} {
      allow read, write: if true; // Add auth rules as needed
    }

    // Account snapshots
    match /account_snapshots/{snapshotId} {
      allow read, write: if true;
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if true
        && request.resource.data.amount != 0
        && (
             // Rule 2.3: expense is strictly negative (< 0)
             (getCategory(request.resource.data.category_id).type == 'expense' && request.resource.data.amount < 0) ||
             // Rule 2.3: income is strictly positive (> 0)
             (getCategory(request.resource.data.category_id).type == 'income' && request.resource.data.amount > 0) ||
             // Rule 2.3: reimbursement is strictly positive (> 0)
             (getCategory(request.resource.data.category_id).type == 'reimbursement' && request.resource.data.amount > 0) ||
             // Rule 2.3: transfer has no sign restriction but must match transfers category
             (getCategory(request.resource.data.category_id).type == 'transfer') ||
             // investment categories
             (getCategory(request.resource.data.category_id).type == 'investment')
           );
    }

    // Asset Transactions collection (historical trade execution receipts)
    match /asset_transactions/{assetTxId} {
      allow read, write: if true
        && request.resource.data.quantity > 0
        && request.resource.data.unit_price > 0;
    }

    // Holdings collection
    match /holdings/{holdingId} {
      allow read, write: if true
        && request.resource.data.quantity >= 0
        && request.resource.data.avg_buy_price >= 0;
    }

    // Recurring Transactions collection
    match /recurring_transactions/{recurringId} {
      allow read, write: if true;
    }

    // Budget Targets collection
    match /budget_targets/{budgetId} {
      allow read, write: if true
        && request.resource.data.target_amount > 0;
    }

    // System Settings collection
    match /system_settings/{settingId} {
      allow read, write: if true;
    }

    // Assets collection
    match /assets/{assetId} {
      allow read, write: if true;
    }
  }
}
